{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dr-bob-mri-viewer",
  "main": "worker/index.ts",
  "compatibility_date": "2026-03-26",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "vars": {
    "MEDGEMMA_MODE": "ollama",
    "MEDGEMMA_MODEL_ID": "dcarrascosa/medgemma-1.5-4b-it:Q8_0",
    "OLLAMA_BASE_URL": "http://192.168.8.150:11434",
    "OLLAMA_TIMEOUT_SECONDS": "120",
    "OLLAMA_NUM_PREDICT": "128",
    "OLLAMA_TEMPERATURE": "0.1",
    "OLLAMA_TOP_P": "0.75",
    "OLLAMA_REPEAT_PENALTY": "1.24"
  }
}
